generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER     // Dono da conta (PJ)
  ADMIN     // Administrador da empresa
  USER      // Usuário comum
  SUPPORT   // Suporte do sistema (você)
}

enum PlanType {
  TRIAL // Período de teste gratuito - 1 dia de teste / 1 cadastro permitido de company e usuário
  BASIC // Plano básico, ideal para pequenas empresas ou uso individual - 1990 por mês / 1 cadastro permitido de company e usuário
  PROFESSIONAL // Plano profissional, ideal para empresas em crescimento - 4990 por mês / até 3 cadastros permitidos de company e usuário
  ENTERPRISE // Plano empresarial, ideal para grandes empresas - Entrar em contato para preço personalizado / cadastros ilimitados de company e usuário
}

enum SubscriptionStatus {
  TRIALING        // Período de teste gratuito
  ACTIVE          // Assinatura ativa e paga
  PAST_DUE        // Pagamento atrasado (Stripe ainda tentando cobrar)
  CANCELED        // Assinatura cancelada
  EXPIRED         // Assinatura expirada (trial ou período acabou)
  INCOMPLETE      // Pagamento inicial falhou
  PENDING_PAYMENT // Aguardando confirmação do pagamento
}

enum InvoiceStatus {
  DRAFT     // Rascunho (ainda não finalizada)
  OPEN      // Aberta (aguardando pagamento)
  PAID      // Paga com sucesso
  VOID      // Anulada
  UNCOLLECTIBLE // Não cobrável
}

enum AccountType {
  ASSET     // Ativo
  LIABILITY // Passivo
  EQUITY    // Patrimônio Líquido
  REVENUE   // Receita
  EXPENSE   // Despesa
}

model User {
  id              String    @id @default(uuid())
  keycloakId      String    @unique
  email           String    @unique
  firstname       String?
  lastname        String?
  role            UserRole  @default(USER)
  pendingPlanType PlanType? // Plano escolhido no onboarding, usado no complete

  // Relação com a Empresa (Multi-tenancy)
  companyId  String?
  company    Company? @relation(fields: [companyId], references: [id])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([role])
  @@index([companyId])
}

model Company {
  id    String  @id @default(uuid())
  name  String
  taxId String? @unique // CNPJ/CPF (opcional no cadastro inicial, preenchido depois)

  // Stripe
  stripeCustomerId String? @unique // ID do customer no Stripe

  // Sub-empresas: hierarquia de empresas filhas (para controle de maxCompany por plano)
  parentCompanyId String?
  parentCompany   Company?  @relation("CompanyChildren", fields: [parentCompanyId], references: [id])
  childCompanies  Company[] @relation("CompanyChildren")

  // Relação com Usuários
  users User[]

  // Relação com Assinatura (Uma empresa tem uma assinatura ativa)
  subscription Subscription?

  // Plano de Contas
  chartOfAccounts ChartOfAccount[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentCompanyId])
}

model Plan {
  id          String   @id @default(uuid())
  type        PlanType @unique
  name        String
  description String?

  priceMonthly Int // Em centavos (ex: 1990 = R$19,90)

  // Stripe
  stripePriceId String? @unique // ID do price no Stripe (ex: price_xxx)

  // Trial
  trialDays Int @default(0) // Dias de teste gratuito (1 para TRIAL)

  // Limites do plano (-1 = ilimitado)
  maxUsers        Int @default(-1) // 1 para Basic, 3 para Professional, -1 para Enterprise
  maxCompany      Int @default(-1) // 1 para Basic, 3 para Professional, -1 para Enterprise
  maxTransactions Int @default(-1) // 1 para Basic, 3 para Professional, -1 para Enterprise
  maxContacts     Int @default(-1) // 1 para Basic, 3 para Professional, -1 para Enterprise

  isActive Boolean @default(true)

  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
}

model Subscription {
  id        String @id @default(uuid())

  // Ligação com a Empresa
  companyId String @unique // Uma empresa tem apenas uma assinatura
  company   Company @relation(fields: [companyId], references: [id])

  // Ligação com o Plano
  planId    String
  plan      Plan   @relation(fields: [planId], references: [id])

  // Stripe
  stripeSubscriptionId String? @unique // ID da subscription no Stripe (ex: sub_xxx)

  status    SubscriptionStatus @default(TRIALING)

  // Período atual de cobrança (atualizado via webhook do Stripe)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?

  // Trial
  trialStart DateTime? // Início do período de teste
  trialEnd   DateTime? // Fim do período de teste

  // Cancelamento
  cancelAtPeriodEnd Boolean @default(false) // Cancela no fim do período atual
  canceledAt        DateTime?               // Data efetiva do cancelamento

  // Invoices (histórico de cobranças)
  invoices Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([planId])
  @@index([status])
}

model Invoice {
  id String @id @default(uuid())

  // Ligação com a Subscription
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])

  // Stripe
  stripeInvoiceId   String? @unique // ID da invoice no Stripe (ex: in_xxx)
  stripePaymentIntentId String?     // ID do payment intent (ex: pi_xxx)

  status      InvoiceStatus @default(DRAFT)
  amountDue   Int           // Valor cobrado em centavos
  amountPaid  Int @default(0) // Valor efetivamente pago em centavos
  currency    String @default("brl")

  // URL do boleto/fatura no Stripe (para o cliente visualizar)
  invoiceUrl  String?
  invoicePdf  String?

  // Período de referência da cobrança
  periodStart DateTime?
  periodEnd   DateTime?

  paidAt DateTime? // Data do pagamento efetivo

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subscriptionId])
  @@index([status])
}

model ChartOfAccount {
  id   String      @id @default(uuid())
  code String
  name String
  type AccountType

  // Multi-tenancy
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  // Hierarquia (conta pai/filhas)
  parentId String?
  parent   ChartOfAccount?  @relation("AccountHierarchy", fields: [parentId], references: [id])
  children ChartOfAccount[] @relation("AccountHierarchy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([code, companyId])
  @@index([companyId])
  @@index([type])
}